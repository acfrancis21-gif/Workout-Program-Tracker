<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Workout">
<meta name="theme-color" content="#080808">
<title>Workout Tracker</title>
<style>
  :root {
    --bg: #080808;
    --surface: #111;
    --card: #181818;
    --border: rgba(255,255,255,0.07);
    --chest1: #e63022;
    --back:   #1a6cf5;
    --legs:   #22c55e;
    --chest2: #f97316;
    --light: #f0ece4;
    --muted: #666;
    --safe-top: env(safe-area-inset-top, 0px);
    --safe-bot: env(safe-area-inset-bottom, 0px);
  }
  * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
  html, body { height:100%; overscroll-behavior:none; }
  body { background:var(--bg); color:var(--light); font-family:-apple-system,'DM Sans',sans-serif; min-height:100vh; }

  /* ── NAV ── */
  .nav {
    display:flex; align-items:center; justify-content:space-between;
    padding:calc(14px + var(--safe-top)) 20px 14px;
    border-bottom:1px solid var(--border);
    position:sticky; top:0;
    background:rgba(8,8,8,0.97);
    backdrop-filter:blur(12px);
    -webkit-backdrop-filter:blur(12px);
    z-index:50;
  }
  .nav-title { font-family:'Georgia',serif; font-size:16px; letter-spacing:2px; font-weight:700; text-transform:uppercase; }
  .nav-right { display:flex; align-items:center; gap:8px; }
  .nav-week { display:flex; align-items:center; gap:6px; }
  .week-btn { background:var(--card); border:1px solid var(--border); color:var(--light); border-radius:8px; padding:5px 11px; cursor:pointer; font-size:17px; transition:background .15s; min-width:36px; }
  .week-btn:active { background:#2a2a2a; }
  .week-label { font-size:13px; font-weight:700; letter-spacing:1.5px; min-width:64px; text-align:center; }
  .icon-btn { background:var(--card); border:1px solid var(--border); color:var(--muted); border-radius:8px; padding:6px 10px; cursor:pointer; font-size:15px; transition:all .15s; }
  .icon-btn:active { background:#222; color:var(--light); }

  /* ── TABS ── */
  .tabs { display:flex; gap:2px; padding:12px 16px 0; overflow-x:auto; scrollbar-width:none; }
  .tabs::-webkit-scrollbar { display:none; }
  .tab { flex-shrink:0; padding:7px 14px; border-radius:8px 8px 0 0; font-size:11px; letter-spacing:1.5px; text-transform:uppercase; font-weight:700; cursor:pointer; border:1px solid transparent; border-bottom:none; transition:all .15s; color:var(--muted); background:transparent; }
  .tab.active { color:#fff; border-color:var(--border); background:var(--card); }
  .tab[data-day="0"].active { border-top-color:var(--chest1); color:var(--chest1); }
  .tab[data-day="1"].active { border-top-color:var(--legs);   color:var(--legs); }
  .tab[data-day="2"].active { border-top-color:var(--back);   color:var(--back); }
  .tab[data-day="3"].active { border-top-color:var(--chest2); color:var(--chest2); }
  .tab[data-day="4"].active { border-top-color:#a855f7; color:#a855f7; }

  /* ── MAIN ── */
  .main { padding:0 16px calc(32px + var(--safe-bot)); max-width:760px; margin:0 auto; }

  /* ── DAY HEADER ── */
  .day-header {
    background:var(--card); border:1px solid var(--border); border-top:none;
    border-radius:0 12px 12px 12px; padding:16px 18px 14px; margin-bottom:12px;
    display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;
  }
  .day-title { font-size:32px; font-weight:900; letter-spacing:1px; line-height:1; font-family:'Georgia',serif; }
  .day-meta { font-size:10px; letter-spacing:1.5px; color:var(--muted); text-transform:uppercase; margin-top:4px; }
  .day-complete-btn { padding:8px 16px; border-radius:8px; border:none; font-size:12px; font-weight:700; cursor:pointer; letter-spacing:0.5px; transition:all .2s; }
  .day-complete-btn.done { background:#1a3a1a; color:var(--legs); border:1px solid rgba(34,197,94,0.3); }
  .day-complete-btn.undone { background:rgba(255,255,255,0.06); color:var(--muted); border:1px solid var(--border); }
  .day-complete-btn.undone:active { background:rgba(255,255,255,0.12); color:var(--light); }

  /* ── EXERCISE CARD ── */
  .ex-card { background:var(--card); border:1px solid var(--border); border-radius:12px; margin-bottom:10px; overflow:hidden; }
  .ex-card-head { display:flex; align-items:center; justify-content:space-between; padding:12px 16px; border-bottom:1px solid var(--border); gap:10px; }
  .ex-card-info { flex:1; }
  .ex-card-name { font-size:14px; font-weight:700; }
  .ex-card-sub { font-size:10px; color:var(--muted); margin-top:2px; line-height:1.4; }
  .ex-prev { font-size:11px; color:var(--muted); text-align:right; line-height:1.5; flex-shrink:0; }
  .ex-prev span { display:block; font-size:9px; letter-spacing:1px; text-transform:uppercase; color:var(--muted); }
  .ex-prev strong { color:var(--light); font-size:12px; }

  /* ── SET ROWS ── */
  .sets-header { display:grid; grid-template-columns:32px 1fr 1fr 40px; gap:6px; padding:7px 16px; font-size:9px; letter-spacing:2px; text-transform:uppercase; color:var(--muted); border-bottom:1px solid var(--border); }
  .set-row { display:grid; grid-template-columns:32px 1fr 1fr 40px; gap:6px; padding:7px 16px; align-items:center; border-bottom:1px solid rgba(255,255,255,0.03); }
  .set-row:last-child { border-bottom:none; }
  .set-num { font-size:16px; font-weight:800; color:var(--muted); text-align:center; }
  .set-input {
    background:rgba(255,255,255,0.05); border:1px solid var(--border);
    border-radius:8px; color:var(--light); font-size:15px; font-weight:600;
    padding:8px 6px; width:100%; text-align:center;
    transition:border .15s, background .15s;
    -webkit-appearance:none; appearance:none;
  }
  .set-input:focus { outline:none; border-color:rgba(255,255,255,0.25); background:rgba(255,255,255,0.09); }
  .set-input.logged { border-color:rgba(34,197,94,0.45); background:rgba(34,197,94,0.07); }
  .set-check {
    width:36px; height:36px; border-radius:8px; border:1px solid var(--border);
    background:transparent; cursor:pointer; display:flex; align-items:center;
    justify-content:center; font-size:16px; transition:all .15s; margin:0 auto;
    user-select:none;
  }
  .set-check.checked { background:rgba(34,197,94,0.15); border-color:rgba(34,197,94,0.5); }

  /* ── TIMER ── */
  .timer-bar {
    display:none; align-items:center; justify-content:space-between;
    background:rgba(26,108,245,0.1); border-top:1px solid rgba(26,108,245,0.2);
    padding:10px 16px; gap:12px;
  }
  .timer-bar.visible { display:flex; }
  .timer-display { font-size:22px; font-weight:800; font-variant-numeric:tabular-nums; color:var(--light); min-width:52px; }
  .timer-display.done-pulse { color:var(--legs); animation:pulse .4s ease 3; }
  .timer-label { font-size:10px; letter-spacing:1.5px; text-transform:uppercase; color:var(--muted); }
  .timer-stop { background:rgba(255,255,255,0.06); border:1px solid var(--border); color:var(--muted); border-radius:6px; padding:5px 12px; cursor:pointer; font-size:11px; font-weight:600; letter-spacing:1px; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

  /* ── PROGRESS ── */
  .progress-section { margin-bottom:22px; padding-top:16px; }
  .progress-title { font-size:18px; font-weight:900; letter-spacing:1px; margin-bottom:10px; font-family:'Georgia',serif; }
  .progress-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(200px,1fr)); gap:8px; }
  .progress-card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:12px 14px; }
  .progress-card-name { font-size:12px; font-weight:700; margin-bottom:8px; }
  .progress-bars { display:flex; flex-direction:column; gap:5px; }
  .progress-week-row { display:flex; align-items:center; gap:8px; }
  .pw-label { font-size:9px; color:var(--muted); letter-spacing:1px; width:38px; flex-shrink:0; }
  .pw-bar-wrap { flex:1; background:rgba(255,255,255,0.05); border-radius:3px; height:5px; overflow:hidden; }
  .pw-bar { height:100%; border-radius:3px; transition:width .5s ease; }
  .pw-val { font-size:9px; color:var(--muted); width:52px; text-align:right; flex-shrink:0; }

  /* ── WEEK OVERVIEW ── */
  .week-overview { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-bottom:16px; }
  .wo-card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:10px 6px; text-align:center; }
  .wo-day { font-size:8px; letter-spacing:1.5px; text-transform:uppercase; color:var(--muted); margin-bottom:3px; }
  .wo-name { font-size:13px; font-weight:800; letter-spacing:0.5px; }
  .wo-status { font-size:16px; margin-top:3px; }

  /* ── BACKUP PANEL ── */
  .backup-panel {
    position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:200;
    display:flex; align-items:flex-end; justify-content:center;
    padding-bottom:var(--safe-bot);
    opacity:0; pointer-events:none; transition:opacity .25s;
  }
  .backup-panel.open { opacity:1; pointer-events:all; }
  .backup-sheet {
    background:#1a1a1a; border:1px solid var(--border); border-radius:20px 20px 0 0;
    width:100%; max-width:500px; padding:24px 24px calc(24px + var(--safe-bot));
    transform:translateY(100%); transition:transform .3s ease;
  }
  .backup-panel.open .backup-sheet { transform:translateY(0); }
  .backup-title { font-size:18px; font-weight:800; margin-bottom:6px; }
  .backup-sub { font-size:12px; color:var(--muted); margin-bottom:20px; line-height:1.5; }
  .backup-btns { display:flex; flex-direction:column; gap:10px; }
  .backup-btn {
    padding:14px 18px; border-radius:10px; border:1px solid var(--border);
    background:rgba(255,255,255,0.05); color:var(--light); font-size:14px;
    font-weight:600; cursor:pointer; text-align:left; display:flex;
    align-items:center; gap:12px; transition:background .15s;
  }
  .backup-btn:active { background:rgba(255,255,255,0.1); }
  .backup-btn .btn-icon { font-size:20px; }
  .backup-btn .btn-text { flex:1; }
  .backup-btn .btn-sub { font-size:11px; color:var(--muted); font-weight:400; display:block; margin-top:2px; }
  .backup-btn.danger { color:#f87171; border-color:rgba(248,113,113,0.2); }
  .backup-close { margin-top:12px; padding:12px; border-radius:10px; border:none; background:transparent; color:var(--muted); font-size:14px; cursor:pointer; width:100%; }

  /* ── EMPTY STATE ── */
  .empty { text-align:center; padding:40px 24px; color:var(--muted); }
  .empty-icon { font-size:40px; margin-bottom:10px; }
  .empty-text { font-size:13px; line-height:1.6; }

  /* ── TOAST ── */
  .toast {
    position:fixed; bottom:calc(24px + var(--safe-bot)); left:50%;
    transform:translateX(-50%) translateY(80px);
    background:#111; color:var(--light); border:1px solid var(--border);
    border-radius:10px; padding:10px 20px; font-size:13px; font-weight:600;
    z-index:999; transition:transform .3s ease; pointer-events:none;
    white-space:nowrap;
  }
  .toast.show { transform:translateX(-50%) translateY(0); }

  /* ── MISC ── */
  input[type=number]::-webkit-inner-spin-button,
  input[type=number]::-webkit-outer-spin-button { -webkit-appearance:none; }
  input[type=number] { -moz-appearance:textfield; }
</style>
</head>
<body>

<!-- NAV -->
<div class="nav">
  <div class="nav-title">💪 Workout</div>
  <div class="nav-right">
    <div class="nav-week">
      <button class="week-btn" id="prevWeek">‹</button>
      <div class="week-label" id="weekLabel">WEEK 1</div>
      <button class="week-btn" id="nextWeek">›</button>
    </div>
    <button class="icon-btn" onclick="openBackup()" title="Backup">⚙️</button>
  </div>
</div>

<div class="tabs" id="tabs"></div>
<div class="main" id="main"></div>

<!-- Rest Timer (shown inside ex cards via JS) -->
<div class="toast" id="toast"></div>

<!-- Backup Panel -->
<div class="backup-panel" id="backupPanel" onclick="closeBackupOutside(event)">
  <div class="backup-sheet">
    <div class="backup-title">Data & Backup</div>
    <div class="backup-sub">Export your workout data as a JSON file to keep a backup, or import a previous backup. Your data is saved in this browser's local storage.</div>
    <div class="backup-btns">
      <button class="backup-btn" onclick="exportData()">
        <span class="btn-icon">📤</span>
        <span class="btn-text">Export Backup<span class="btn-sub">Download all your workout data as a .json file</span></span>
      </button>
      <button class="backup-btn" onclick="document.getElementById('importFile').click()">
        <span class="btn-icon">📥</span>
        <span class="btn-text">Import Backup<span class="btn-sub">Restore from a previously exported .json file</span></span>
      </button>
      <button class="backup-btn danger" onclick="confirmClear()">
        <span class="btn-icon">🗑️</span>
        <span class="btn-text">Clear All Data<span class="btn-sub">Permanently delete all logged workouts</span></span>
      </button>
    </div>
    <button class="backup-close" onclick="closeBackup()">Close</button>
    <input type="file" id="importFile" accept=".json" style="display:none" onchange="importData(event)">
  </div>
</div>

<script>
// ── PROGRAM ──
const PROGRAM = [
  {
    id:'chest1', label:'Chest', sublabel:'Heavy · Compound Focus', color:'var(--chest1)',
    exercises:[
      {name:'Barbell Bench Press',    sets:4, reps:'5',  note:'75–80% 1RM · 3 min rest'},
      {name:'Incline Dumbbell Press', sets:3, reps:'10', note:'30–45° incline · 2 min rest'},
      {name:'Cable Fly / Pec Deck',   sets:3, reps:'15', note:'Full stretch · 1–2 min rest'},
      {name:'Chest Dips',             sets:3, reps:'12', note:'Lean forward · add weight if easy'},
    ]
  },
  {
    id:'legs', label:'Legs', sublabel:'Quad · Hamstring · Glute · Calf', color:'var(--legs)',
    exercises:[
      {name:'Back Squat',         sets:4, reps:'5',  note:'75–80% 1RM · Knees out · 3–4 min rest'},
      {name:'Romanian Deadlift',  sets:3, reps:'10', note:'Hip hinge · feel the stretch · 2–3 min'},
      {name:'Leg Press',          sets:3, reps:'15', note:"Full depth · don't lock out · 2 min rest"},
      {name:'Leg Curl',           sets:3, reps:'12', note:'Slow eccentric · 1–2 min rest'},
      {name:'Calf Raises',        sets:4, reps:'20', note:'Full stretch · pause at top'},
    ]
  },
  {
    id:'back', label:'Back', sublabel:'Pull · Strength & Width', color:'var(--back)',
    exercises:[
      {name:'Deadlift',              sets:3, reps:'5',  note:'80% 1RM · 3–4 min rest'},
      {name:'Barbell Bent-Over Row', sets:4, reps:'8',  note:'Pull to lower chest · 2–3 min rest'},
      {name:'Lat Pulldown',          sets:3, reps:'12', note:'Elbows down & in · 2 min rest'},
      {name:'Seated Cable Row',      sets:3, reps:'12', note:'Full stretch · squeeze at end'},
      {name:'Face Pulls',            sets:3, reps:'20', note:'External rotation finish · 1 min rest'},
    ]
  },
  {
    id:'chest2', label:'Chest 2', sublabel:'Volume · Isolation · Pump', color:'var(--chest2)',
    exercises:[
      {name:'Incline Dumbbell Press', sets:4, reps:'12', note:'3-sec lowering · 2 min rest'},
      {name:'Cable Crossover',        sets:3, reps:'15', note:'High-to-low · full stretch · 1–2 min'},
      {name:'Machine Chest Press',    sets:3, reps:'15', note:"Constant tension · don't lock out"},
      {name:'Push-Ups to Failure',    sets:2, reps:'F',  note:'Wide grip · chest to floor · 60 sec rest'},
    ]
  },
  {id:'progress', label:'Progress', sublabel:'All time', color:'#a855f7', exercises:[]}
];

const DAY_NAMES = ['Monday','Tuesday','Thursday','Saturday'];
const STORAGE_KEY = 'workoutTrackerV2';

// ── STATE ──
let currentWeek = 1;
let currentDay  = 0;
let allData = {};
let timerInterval = null;
let timerSeconds  = 0;
let timerEl = null;

// ── LOCALSTORAGE ──
function loadData() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) allData = JSON.parse(raw);
  } catch(e) { allData = {}; }
}

function saveData() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(allData)); }
  catch(e) { showToast('⚠️ Storage full — export a backup!'); }
}

// ── DATA HELPERS ──
function getKey(w,d){ return `w${w}d${d}`; }

function getDayData(w,d){
  const key = getKey(w,d);
  if(!allData[key]){
    allData[key]={
      completed:false,
      sets: PROGRAM[d].exercises.map(ex=>
        Array.from({length:ex.sets},()=>({weight:'',reps:'',done:false}))
      )
    };
  }
  return allData[key];
}

function getPrevSet(d,ei,si){
  for(let w=currentWeek-1;w>=1;w--){
    const key=getKey(w,d);
    if(allData[key]){
      const s=allData[key].sets[ei]?.[si];
      if(s&&s.weight) return s;
    }
  }
  return null;
}

// ── RENDER ──
function render(){
  renderTabs();
  currentDay===4 ? renderProgress() : renderDay();
}

function renderTabs(){
  document.getElementById('tabs').innerHTML = PROGRAM.map((d,i)=>`
    <div class="tab ${i===currentDay?'active':''}" data-day="${i}" onclick="switchDay(${i})">${d.label}</div>
  `).join('');
}

function renderDay(){
  const day  = PROGRAM[currentDay];
  const data = getDayData(currentWeek, currentDay);
  document.getElementById('main').innerHTML = `
    <div class="day-header">
      <div>
        <div class="day-title" style="color:${day.color}">${day.label.toUpperCase()}</div>
        <div class="day-meta">Week ${currentWeek} · ${DAY_NAMES[currentDay]||''} · ${day.sublabel}</div>
      </div>
      <button class="day-complete-btn ${data.completed?'done':'undone'}" onclick="toggleComplete()">
        ${data.completed?'✅ Done':'Mark Complete'}
      </button>
    </div>
    ${day.exercises.map((ex,ei)=>renderExCard(ex,ei,data,day)).join('')}
  `;
}

function renderExCard(ex,ei,data,day){
  const sets = data.sets[ei]||[];
  const prev0 = getPrevSet(currentDay,ei,0);
  const prevHtml = prev0&&prev0.weight
    ? `<div class="ex-prev"><span>Last week</span><strong>${prev0.weight} lbs × ${prev0.reps}</strong></div>`
    : '';

  const setRows = sets.map((s,si)=>{
    const ps = getPrevSet(currentDay,ei,si);
    return `
      <div class="set-row" id="setrow-${ei}-${si}">
        <div class="set-num">${si+1}</div>
        <input class="set-input ${s.weight?'logged':''}" type="number" inputmode="decimal" min="0" step="2.5"
          placeholder="${ps?ps.weight:'0'}" value="${s.weight}"
          onchange="updateSet(${ei},${si},'weight',this.value)"
          onfocus="this.select()">
        <input class="set-input ${s.reps?'logged':''}" type="number" inputmode="numeric" min="0"
          placeholder="${ps?ps.reps:ex.reps}" value="${s.reps}"
          onchange="updateSet(${ei},${si},'reps',this.value)"
          onfocus="this.select()">
        <div class="set-check ${s.done?'checked':''}" onclick="toggleSet(${ei},${si})">${s.done?'✓':''}</div>
      </div>
    `;
  }).join('');

  return `
    <div class="ex-card">
      <div class="ex-card-head">
        <div class="ex-card-info">
          <div class="ex-card-name">${ex.name}</div>
          <div class="ex-card-sub">${ex.sets} sets · ${ex.reps} reps · ${ex.note}</div>
        </div>
        ${prevHtml}
      </div>
      <div class="sets-header"><div>Set</div><div style="text-align:center">lbs</div><div style="text-align:center">Reps</div><div></div></div>
      ${setRows}
      <div class="timer-bar" id="timer-${ei}">
        <div>
          <div class="timer-label">REST TIMER</div>
          <div class="timer-display" id="timerDisplay-${ei}">0:00</div>
        </div>
        <button class="timer-stop" onclick="stopTimer(${ei})">Stop</button>
      </div>
    </div>
  `;
}

function renderProgress(){
  const overviewCards = PROGRAM.slice(0,4).map((day,di)=>{
    const data=getDayData(currentWeek,di);
    return `<div class="wo-card">
      <div class="wo-day">Day ${di+1}</div>
      <div class="wo-name" style="color:${day.color}">${day.label}</div>
      <div class="wo-status">${data.completed?'✅':'⬜'}</div>
    </div>`;
  }).join('');

  const exSections = PROGRAM.slice(0,4).map((day,di)=>{
    const cards = day.exercises.map((ex,ei)=>{
      const pts=[];
      for(let w=1;w<=currentWeek;w++){
        const key=getKey(w,di);
        if(!allData[key]) continue;
        const maxW=Math.max(...(allData[key].sets[ei]||[]).map(s=>parseFloat(s.weight)||0));
        if(maxW>0) pts.push({w,weight:maxW});
      }
      if(!pts.length) return '';
      const maxAll=Math.max(...pts.map(x=>x.weight));
      return `<div class="progress-card">
        <div class="progress-card-name">${ex.name}</div>
        <div class="progress-bars">${pts.map(x=>`
          <div class="progress-week-row">
            <div class="pw-label">WK ${x.w}</div>
            <div class="pw-bar-wrap"><div class="pw-bar" style="width:${Math.round(x.weight/maxAll*100)}%;background:${day.color}"></div></div>
            <div class="pw-val">${x.weight} lbs</div>
          </div>`).join('')}
        </div>
      </div>`;
    }).filter(Boolean).join('');
    if(!cards) return '';
    return `<div class="progress-section">
      <div class="progress-title" style="color:${day.color}">${day.label}</div>
      <div class="progress-grid">${cards}</div>
    </div>`;
  }).join('');

  document.getElementById('main').innerHTML = `
    <div>
      <div style="padding-top:16px;font-size:18px;font-weight:900;letter-spacing:1px;margin-bottom:10px;color:#a855f7;font-family:'Georgia',serif">WEEK ${currentWeek} STATUS</div>
      <div class="week-overview">${overviewCards}</div>
      ${exSections||`<div class="empty"><div class="empty-icon">📊</div><div class="empty-text">No data yet.<br>Start logging sets to see your progress.</div></div>`}
    </div>
  `;
}

// ── ACTIONS ──
function switchDay(i){ currentDay=i; render(); window.scrollTo(0,0); }

function updateSet(ei,si,field,val){
  const data=getDayData(currentWeek,currentDay);
  data.sets[ei][si][field]=val;
  // Update input styling inline
  const row=document.getElementById(`setrow-${ei}-${si}`);
  if(row){
    row.querySelectorAll('.set-input').forEach(inp=>{
      inp.value ? inp.classList.add('logged') : inp.classList.remove('logged');
    });
  }
  saveData();
}

function toggleSet(ei,si){
  const data=getDayData(currentWeek,currentDay);
  const s=data.sets[ei][si];
  s.done=!s.done;
  saveData();
  // Update check without full render
  const row=document.getElementById(`setrow-${ei}-${si}`);
  if(row){
    const chk=row.querySelector('.set-check');
    chk.classList.toggle('checked',s.done);
    chk.textContent=s.done?'✓':'';
  }
  // Start rest timer when set is checked
  if(s.done) startTimer(ei);
}

function toggleComplete(){
  const data=getDayData(currentWeek,currentDay);
  data.completed=!data.completed;
  saveData();
  render();
  if(data.completed) showToast('Day complete! 💪');
}

// ── REST TIMER ──
function startTimer(ei){
  stopTimer(timerEl);
  timerEl=ei;
  timerSeconds=0;
  const bar=document.getElementById(`timer-${ei}`);
  const disp=document.getElementById(`timerDisplay-${ei}`);
  if(!bar||!disp) return;
  bar.classList.add('visible');
  clearInterval(timerInterval);
  timerInterval=setInterval(()=>{
    timerSeconds++;
    const m=Math.floor(timerSeconds/60);
    const s=String(timerSeconds%60).padStart(2,'0');
    disp.textContent=`${m}:${s}`;
    // Pulse at 2min for compound, 90s for isolation
    if(timerSeconds===120||timerSeconds===90){
      disp.classList.add('done-pulse');
      setTimeout(()=>disp.classList.remove('done-pulse'),1500);
      showToast('⏱️ Rest time up — next set!');
    }
  },1000);
}

function stopTimer(ei){
  clearInterval(timerInterval);
  if(ei!==null&&ei!==undefined){
    const bar=document.getElementById(`timer-${ei}`);
    if(bar) bar.classList.remove('visible');
  }
  timerEl=null; timerSeconds=0;
}

// ── WEEK NAV ──
document.getElementById('prevWeek').onclick=()=>{
  if(currentWeek>1){ currentWeek--; document.getElementById('weekLabel').textContent=`WEEK ${currentWeek}`; render(); }
};
document.getElementById('nextWeek').onclick=()=>{
  currentWeek++; document.getElementById('weekLabel').textContent=`WEEK ${currentWeek}`; render();
};

// ── TOAST ──
let toastTimer=null;
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),2600);
}

// ── BACKUP ──
function openBackup(){ document.getElementById('backupPanel').classList.add('open'); }
function closeBackup(){ document.getElementById('backupPanel').classList.remove('open'); }
function closeBackupOutside(e){ if(e.target===document.getElementById('backupPanel')) closeBackup(); }

function exportData(){
  const blob=new Blob([JSON.stringify({version:2,exported:new Date().toISOString(),data:allData},null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url; a.download=`workout-backup-${new Date().toISOString().slice(0,10)}.json`;
  a.click(); URL.revokeObjectURL(url);
  showToast('✅ Backup exported!');
  closeBackup();
}

function importData(e){
  const file=e.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=ev=>{
    try{
      const parsed=JSON.parse(ev.target.result);
      const imported=parsed.data||parsed;
      Object.assign(allData,imported);
      saveData(); render();
      showToast('✅ Backup imported!');
      closeBackup();
    }catch(err){ showToast('❌ Invalid backup file'); }
  };
  reader.readAsText(file);
  e.target.value='';
}

function confirmClear(){
  if(confirm('Delete ALL workout data? This cannot be undone.')){
    allData={};
    localStorage.removeItem(STORAGE_KEY);
    render();
    showToast('🗑️ All data cleared');
    closeBackup();
  }
}

// ── INIT ──
loadData();
document.getElementById('weekLabel').textContent=`WEEK ${currentWeek}`;
render();
</script>
</body>
</html>
